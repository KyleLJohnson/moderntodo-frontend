@using BlazorTodo.Models

<div class="task-card @(Task.IsCompleted ? "completed" : "") priority-@Task.Priority.ToString().ToLower()">
    <div class="task-card-left">
        <button class="complete-btn @(Task.IsCompleted ? "is-done" : "")"
                @onclick="HandleToggle"
                title="@(Task.IsCompleted ? "Mark incomplete" : "Mark complete")">
            @if (Task.IsCompleted)
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
            }
        </button>
    </div>
    <div class="task-card-body">
        <div class="task-title">@Task.Title</div>
        @if (!string.IsNullOrWhiteSpace(Task.Description))
        {
            <div class="task-description">@Task.Description</div>
        }
        <div class="task-meta">
            <span class="priority-badge priority-@Task.Priority.ToString().ToLower()">@Task.Priority</span>
            @if (Task.DueDate.HasValue)
            {
                var isOverdue = !Task.IsCompleted && Task.DueDate.Value.Date < DateTime.Today;
                <span class="due-date @(isOverdue ? "overdue" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    @Task.DueDate.Value.ToString("MMM d")
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Task.TaskTime))
            {
                <span class="task-time">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                    @Task.TaskTime
                </span>
            }
        </div>
    </div>
    <div class="task-card-actions">
        <button class="icon-btn" @onclick="() => OnEdit.InvokeAsync(Task)" title="Edit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
        </button>
        <button class="icon-btn danger" @onclick="HandleDelete" title="Delete">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                <path d="M10 11v6M14 11v6" />
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public TaskDto Task { get; set; } = default!;
    [Parameter] public EventCallback<TaskDto> OnEdit { get; set; }
    [Parameter] public EventCallback<TaskDto> OnToggleComplete { get; set; }
    [Parameter] public EventCallback<TaskDto> OnDelete { get; set; }

    private Task HandleToggle() => OnToggleComplete.InvokeAsync(Task);
    private Task HandleDelete() => OnDelete.InvokeAsync(Task);
}
